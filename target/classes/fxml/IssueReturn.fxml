<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="400.0" prefWidth="600.0" style="-fx-background-color: #f5f5f5;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.library.controller.IssueReturnController">

    <!-- Top Bar -->
    <top>
        <HBox style="-fx-background-color: #2c3e50; -fx-padding: 10;" alignment="CENTER_LEFT">
            <Label text="Issue and Return Book" textFill="WHITE">
                <font>
                    <Font name="System Bold" size="20.0" />
                </font>
            </Label>
        </HBox>
    </top>

    <!-- Main Content -->
    <center>
        <VBox spacing="25.0" style="-fx-padding: 50;" alignment="CENTER">
            <!-- Issue Book Section -->
            <VBox spacing="15.0" style="-fx-border-color: #bdc3c7; -fx-border-radius: 5; -fx-padding: 20; -fx-background-color: white;">
                <Label text="Issue a Book" style="-fx-text-fill: #2c3e50; -fx-font-weight: bold;">
                    <font>
                        <Font size="16.0" />
                    </font>
                </Label>

                <VBox spacing="8.0">
                    <Label text="Select Book:" style="-fx-text-fill: #2c3e50;" />
                    <ComboBox fx:id="bookComboBox" promptText="Choose a book" prefWidth="400.0" style="-fx-font-size: 12;" />
                </VBox>

                <VBox spacing="8.0">
                    <Label text="Select Student:" style="-fx-text-fill: #2c3e50;" />
                    <ComboBox fx:id="studentComboBox" promptText="Choose a student" prefWidth="400.0" style="-fx-font-size: 12;" />
                </VBox>

                <Label fx:id="issueStatusLabel" text="" textFill="#27ae60" />

                <Button fx:id="issueBtn" text="Issue Book" style="-fx-font-size: 14; -fx-padding: 10 40; -fx-background-color: #f39c12; -fx-text-fill: white;" />
            </VBox>

            <!-- Return Book Section -->
            <VBox spacing="15.0" style="-fx-border-color: #bdc3c7; -fx-border-radius: 5; -fx-padding: 20; -fx-background-color: white;">
                <Label text="Return a Book" style="-fx-text-fill: #2c3e50; -fx-font-weight: bold;">
                    <font>
                        <Font size="16.0" />
                    </font>
                </Label>

                <VBox spacing="8.0">
                    <Label text="Select Book:" style="-fx-text-fill: #2c3e50;" />
                    <ComboBox fx:id="returnBookComboBox" promptText="Choose a book to return" prefWidth="400.0" style="-fx-font-size: 12;" />
                </VBox>

                <VBox spacing="8.0">
                    <Label text="Select Student:" style="-fx-text-fill: #2c3e50;" />
                    <ComboBox fx:id="returnStudentComboBox" promptText="Choose a student" prefWidth="400.0" style="-fx-font-size: 12;" />
                </VBox>

                <Label fx:id="returnStatusLabel" text="" textFill="#27ae60" />

                <Button fx:id="returnBtn" text="Return Book" style="-fx-font-size: 14; -fx-padding: 10 40; -fx-background-color: #9b59b6; -fx-text-fill: white;" />
            </VBox>
        </VBox>
    </center>

    <!-- Bottom Bar -->
    <bottom>
        <HBox spacing="15.0" style="-fx-padding: 20;" alignment="CENTER">
            <Button fx:id="backBtn" text="Back to Dashboard" onAction="#onBack" style="-fx-font-size: 12; -fx-padding: 8 30; -fx-background-color: #95a5a6; -fx-text-fill: white;" />
        </HBox>
    </bottom>

</BorderPane>
