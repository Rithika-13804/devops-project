<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="500.0" prefWidth="700.0" style="-fx-background-color: #f5f5f5;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.library.controller.AddBookController">

    <!-- Top Bar -->
    <top>
        <HBox style="-fx-background-color: #2c3e50; -fx-padding: 10;" alignment="CENTER_LEFT">
            <Label text="Add New Book" textFill="WHITE">
                <font>
                    <Font name="System Bold" size="20.0" />
                </font>
            </Label>
        </HBox>
    </top>

    <!-- Main Content -->
    <center>
        <VBox spacing="20.0" style="-fx-padding: 40;" alignment="TOP_CENTER">
            <!-- Form Fields -->
            <VBox spacing="10.0">
                <Label text="Book Title:" style="-fx-text-fill: #2c3e50; -fx-font-size: 14;">
                    <font>
                        <Font name="System Bold" size="14.0" />
                    </font>
                </Label>
                <TextField fx:id="titleField" promptText="Enter book title" style="-fx-font-size: 12;" />
            </VBox>

            <VBox spacing="10.0">
                <Label text="Author Name:" style="-fx-text-fill: #2c3e50;">
                    <font>
                        <Font name="System Bold" size="14.0" />
                    </font>
                </Label>
                <TextField fx:id="authorField" promptText="Enter author name" style="-fx-font-size: 12;" />
            </VBox>

            <VBox spacing="10.0">
                <Label text="ISBN:" style="-fx-text-fill: #2c3e50;">
                    <font>
                        <Font name="System Bold" size="14.0" />
                    </font>
                </Label>
                <TextField fx:id="isbnField" promptText="Enter ISBN" style="-fx-font-size: 12;" />
            </VBox>

            <VBox spacing="10.0">
                <Label text="Category:" style="-fx-text-fill: #2c3e50;">
                    <font>
                        <Font name="System Bold" size="14.0" />
                    </font>
                </Label>
                <TextField fx:id="categoryField" promptText="Enter category (e.g., Programming, Fiction)" style="-fx-font-size: 12;" />
            </VBox>

            <!-- Status Message -->
            <Label fx:id="statusLabel" text="" textFill="#27ae60" style="-fx-padding: 10;" />

            <!-- Buttons -->
            <HBox spacing="15.0" alignment="CENTER" style="-fx-padding: 20;">
                <Button fx:id="addBtn" text="Add Book" onAction="#onAddBook" style="-fx-font-size: 14; -fx-padding: 10 30; -fx-background-color: #27ae60; -fx-text-fill: white;" />
                <Button fx:id="backBtn" text="Back" onAction="#onBack" style="-fx-font-size: 14; -fx-padding: 10 30; -fx-background-color: #95a5a6; -fx-text-fill: white;" />
            </HBox>
        </VBox>
    </center>

</BorderPane>
